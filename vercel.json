{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "public/widget/**", "use": "@vercel/static" },
    { "src": "public/admin/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/widget/(.*)", "dest": "/public/widget/$1" },
    { "src": "/admin", "dest": "/public/admin/index.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
